<Window x:Class="RobloxShortcutGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roblox Shortcut Generator" Height="350" Width="400" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="DarkenHoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFF9B51"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#E67E22"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#D35400"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="Gray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Background>
        <!-- This must match your filename from Step 3 -->
        <ImageBrush ImageSource="/360_F_317571717_OJRxoKfD6aaxWEQmV0xmXgVoM9mKcn8q.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Game Place ID" FontWeight="Bold" Foreground="White"/>
        <TextBox x:Name="TxtPlaceId" Margin="0,5,0,15" Padding="5" Background="#CCBFC9D1" Opacity="0.6"/>

        <TextBlock Text="Link Code (Optional Private Server)" FontWeight="Bold" Foreground="White"/>
        <TextBox x:Name="TxtLinkCode" Margin="0,5,0,15" Padding="5" Background="#CCBFC9D1" Opacity="0.6"/>

        <TextBlock Text="Shortcut Name" FontWeight="Bold" Foreground="White"/>
        <TextBox x:Name="TxtLauncherName" Margin="0,5,0,20" Padding="5" Background="#CCBFC9D1" Opacity="0.6"/>

        <Button x:Name="BtnCreate" Content="Create Desktop Shortcut" Height="40" 
                Click="BtnCreate_Click" Style="{StaticResource DarkenHoverButtonStyle}">
            <Button.RenderTransform>
                <RotateTransform Angle="0" CenterX="180" CenterY="20"/>
            </Button.RenderTransform>
        </Button>

        <TextBlock x:Name="StatusLabel" Text="Ready" Margin="0,10,0,0" HorizontalAlignment="Center" Foreground="White">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1"/>
            </TextBlock.Effect>
        </TextBlock>
    </StackPanel>
</Window>